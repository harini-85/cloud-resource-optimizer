# MongoDB Configuration - MongoDB Atlas
# Cluster: cloud-cluster.vg7rdfo.mongodb.net
# Username: admin
# Password: cloud123
MONGODB_URI=mongodb+srv://admin:cloud123@cloud-cluster.vg7rdfo.mongodb.net/cloud_optimizer?retryWrites=true&w=majority&appName=cloud-cluster

# AWS Configuration
# NOTE: AWS credentials should NOT be configured here!
# Users provide their AWS credentials when connecting their cloud account in the UI.
# The region is automatically detected from the user's AWS account.
# These environment variables are ONLY used by diagnostic scripts (check_aws_permissions.js, etc.)
# AWS_ACCESS_KEY_ID=your_key_here_for_diagnostics_only
# AWS_SECRET_ACCESS_KEY=your_secret_here_for_diagnostics_only

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Secret
JWT_SECRET=cloud-optimizer-secret-key-2024

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ML Service URL
ML_SERVICE_URL=http://localhost:8000

# PostgreSQL Configuration
POSTGRES_URL=postgresql://postgres:root@localhost:5432/cloud_optimizer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cloud_optimizer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root

# Metrics Window Configuration
# Number of days to fetch metrics data (7, 14, or 30)
# Default: 7 days for faster sync (recommended for development)
# Use 30 days for production for more stable recommendations
METRICS_WINDOW_DAYS=7

# Gemini AI Configuration (Optional)
# If not provided, the service will operate in fallback-only mode
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyC-p7bJ9oRj23ry6EgnWJqESTleGf-Fb-c

# CPU + Memory Recommendation System Configuration
# Thresholds for rightsizing recommendations

# Oversized Instance Thresholds
OVERSIZED_CPU_AVG_THRESHOLD=20
OVERSIZED_CPU_P95_THRESHOLD=40
OVERSIZED_MEMORY_AVG_THRESHOLD=30
OVERSIZED_MEMORY_P95_THRESHOLD=50

# Undersized Instance Thresholds
UNDERSIZED_CPU_P95_THRESHOLD=80
UNDERSIZED_MEMORY_P95_THRESHOLD=80

# Confidence Thresholds
MIN_CONFIDENCE_DISPLAY=0.50
LOW_CONFIDENCE_THRESHOLD=0.75

# Azure Native Recommendations Configuration
AZURE_NATIVE_RECOMMENDATIONS_ENABLED=true
AZURE_BATCH_SIZE=50
AZURE_MAX_RETRIES=3
AZURE_TIMEOUT_MS=30000
AZURE_CACHE_ENABLED=true
AZURE_CACHE_TTL_HOURS=24
AZURE_CONCURRENCY=5


