# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Server Configuration
PORT=8081
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-secret-key-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ML Service URL
ML_SERVICE_URL=http://localhost:5000

# PostgreSQL Configuration
POSTGRES_URL=postgresql://username:password@localhost:5432/database_name

# Metrics Window Configuration
# Number of days to fetch metrics data (7, 14, or 30)
# Default: 7 days for faster sync (recommended for development)
# Use 30 days for production for more stable recommendations
METRICS_WINDOW_DAYS=7

# Gemini AI Configuration (Optional)
# If not provided, the service will operate in fallback-only mode with predefined messages
# The system will continue to work normally, but AI-generated explanations will be replaced with fallback strings
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# CPU + Memory Recommendation System Configuration
# Thresholds for rightsizing recommendations

# Oversized Instance Thresholds
OVERSIZED_CPU_AVG_THRESHOLD=20
OVERSIZED_CPU_P95_THRESHOLD=40
OVERSIZED_MEMORY_AVG_THRESHOLD=30
OVERSIZED_MEMORY_P95_THRESHOLD=50

# Undersized Instance Thresholds
UNDERSIZED_CPU_P95_THRESHOLD=80
UNDERSIZED_MEMORY_P95_THRESHOLD=80

# Confidence Thresholds
MIN_CONFIDENCE_DISPLAY=0.50
LOW_CONFIDENCE_THRESHOLD=0.75

# Azure Native Recommendations Configuration
# Enable/disable Azure native recommendations (bypasses ML service)
AZURE_NATIVE_RECOMMENDATIONS_ENABLED=false
# Batch size for Azure API calls (max 100)
AZURE_BATCH_SIZE=50
# Maximum retry attempts for transient failures
AZURE_MAX_RETRIES=3
# Timeout for Azure API calls in milliseconds
AZURE_TIMEOUT_MS=30000
# Enable/disable caching of Azure pricing data
AZURE_CACHE_ENABLED=true
# Cache TTL for Azure pricing data in hours
AZURE_CACHE_TTL_HOURS=24
# Number of concurrent region processing operations
AZURE_CONCURRENCY=5

# ============================================================================
# CLOUD PROVIDER CREDENTIALS - FOR DIAGNOSTIC AND DATA FETCHING SCRIPTS
# ============================================================================
# NOTE: Do NOT configure these credentials for the main application!
# Users provide their cloud credentials when connecting their cloud account in the UI.
#
# These environment variables are used by:
# 1. Diagnostic scripts (check_aws_permissions.js, etc.)
# 2. Data fetching scripts (fetch_all_pricing_data.js)
#
# To use these scripts, uncomment and add your credentials:

# AWS Credentials
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# Azure Credentials (for data fetching)
# AZURE_SUBSCRIPTION_ID=your_subscription_id
# AZURE_CLIENT_ID=your_client_id
# AZURE_CLIENT_SECRET=your_client_secret
# AZURE_TENANT_ID=your_tenant_id

# GCP Credentials (for data fetching)
# GCP_PROJECT_ID=your_project_id
# GCP_API_KEY=your_api_key
# OR use service account:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json